# PostgreSQL Configuration
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=
FRONTEND_PORT=3000

# Use this from Docker services.
DATABASE_URL=

# Redis/Celery settings for Docker Compose.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Optional. Defaults to ./generated when running outside Docker.
# GENERATED_DIR=/absolute/path/to/generated

# Use this from your host shell when running the CLI against Docker Postgres.
# DATABASE_URL=postgresql://library_user:12345678@localhost:5433/library_management_fast_api
